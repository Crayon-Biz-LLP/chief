{
    "functions": {
        "api/index.py": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/pulse",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/research",
            "schedule": "*/15 * * * *"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/admin",
            "dest": "/api/index.py"
        },
        {
            "src": "/",
            "dest": "/api/index.py"
        }
    ]
}